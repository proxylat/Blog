{
  "name": "aeternam",
  "version": "1.0.0",
  "description": "Optimized Jekyll website.",
  "type": "module",
  "scripts": {
    "build:jekyll": "bundle exec jekyll build --config _config.yml",
    "optimize:images": "node scripts/optimize-images.js",
    "optimize:css": "node scripts/optimize-css.js",
    "inline:css": "node scripts/inline-css.js",
    "size:html": "node scripts/size.js",
    "minify:html": "node scripts/minify.js",
    "build": "npm run build:jekyll && npm run optimize:css && npm run inline:css && npm run size:html && npm run minify:html"
  },
  "keywords": [
    "jekyll",
    "optimization",
    "performance"
  ],
  "author": "AETERNAM",
  "license": "ISC",
  "devDependencies": {
    "@minify-html/node": "^0.16.4",
    "dropcss": "^1.0.16",
    "lightningcss": "^1.30.1",
    "sharp": "^0.34.5"
  }
}
