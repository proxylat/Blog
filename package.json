{
  "name": "aeternam",
  "version": "1.0.0",
  "description": "Optimized Jekyll website.",
  "directories": {
    "lib": "lib"
  },
  "scripts": {
    "build:jekyll": "bundle exec jekyll build --config _config.yml",
    "copy:headers": "node scripts/copy-headers.js",
    "optimize:css": "node scripts/optimize-css.js",
    "beasties:css": "node scripts/beasties.mjs",
    "inline:css": "node scripts/inline-css.cjs",
    "size:html": "node scripts/size.js",
    "minify:html": "node scripts/minify.js",
    "build": "npm run build:jekyll && npm run copy:headers && npm run optimize:css && npm run beasties:css && npm run inline:css && npm run size:html && npm run minify:html"
  },
  "keywords": [
    "jekyll",
    "optimization",
    "performance"
  ],
  "author": "AETERNAM",
  "license": "ISC",
  "devDependencies": {
    "@minify-html/node": "^0.16.4",
    "beasties": "^0.3.4",
    "dropcss": "^1.0.16",
    "lightningcss": "^1.30.1",
    "puppeteer": "npm:puppeteer-core@^24.10.2"
  },
  "overrides": {
    "beasties": {
      "puppeteer": "npm:puppeteer-core@^24.10.2"
    }
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.0",
    "image-size": "^2.0.2",
    "jsdom": "^26.1.0"
  }
}
